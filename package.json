{
  "name": "redlineacademy.github.io",
  "version": "1.0.0",
  "description": "Website modern dan responsif untuk Redline Academy dengan dukungan multi-language (Indonesia dan Inggris).",
  "main": "index.js",
  "scripts": {
    "test": "node tools/run-live-project.js local-regression",
    "test:smoke": "node tools/run-live-project.js local-smoke",
    "test:regression": "node tools/run-live-project.js local-regression",
    "test:real": "npm run test:regression && npm run seo:validate",
    "test:real:all": "npm run test:real && npm run test:live",
    "lint": "eslint .",
    "test:e2e": "node tools/run-live-project.js local-regression",
    "test:live:core": "node tools/run-live-project.js live-core",
    "test:live:audit": "node tools/run-live-project.js live-audit",
    "test:live": "npm run test:live:core && npm run test:live:audit",
    "test:unit": "jest --passWithNoTests",
    "qa:report": "node tools/qa-observability.js report",
    "format": "prettier --write .",
    "seo:generate": "node tools/generate-seo-pages.js --input data/seo-keywords.sample.json --update-sitemap",
    "seo:validate": "node scripts/validate-seo-structure.js",
    "seo:build": "node tools/generate-seo-pages.js --input data/seo-keywords.sample.json --update-sitemap --overwrite && node scripts/validate-seo-structure.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "eslint": "^10.0.3",
    "jest": "^30.2.0",
    "prettier": "^3.7.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "dotenv": "^17.3.1"
  }
}
